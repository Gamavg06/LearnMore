// Nota: Para que esto funcione, necesitas crear las tablas correspondientes en Supabase:
// - guides (id, title, desc, detail, career, sem, topics, fileUrl, created_at, updated_at)
// - careers (id, key, name, desc, color)
// - messages (id, name, email, career, subject, message, status, created_at, updated_at)
// - users (id, name, email, role, password, created_at, updated_at)
// - activity (id, type, text, created_at, updated_at)

// Función genérica para obtener una referencia a una tabla (similar a collection en Firestore)
export function collection(tableName) {
  if (!supabaseReady) throw new Error("Supabase no está listo");
  return supabase.from(tableName);
}

// Función genérica para obtener una referencia a un documento (similar a doc en Firestore)
export function doc(tableName, id) {
  if (!supabaseReady) throw new Error("Supabase no está listo");
  return supabase.from(tableName).eq('id', id);
}

// Función para agregar un documento (similar a addDoc en Firestore)
export async function addDoc(tableReference, data) {
  if (!supabaseReady) throw new Error("Supabase no está listo");
  
  // Extraer el nombre de la tabla de la referencia (esto es una simplificación)
  // En una implementación más robusta, pasaríamos el nombre de la tabla directamente
  const tableName = tableReference; // Asumiendo que tableReference es el nombre de la tabla
  
  const { data: result, error } = await supabase
    .from(tableName)
    .insert({ 
      ...data, 
      created_at: new Date().toISOString(),
      updated_at: new Date().toISOString()
    })
    .select()
    .single();
    
  if (error) throw error;
  return result;
}

// Función para establecer un documento (similar a setDoc en Firestore)
